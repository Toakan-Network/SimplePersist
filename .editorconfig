# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Windows-style newlines with a newline ending every file
[*]
end_of_line = crlf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# Tab indentation for config and SQF files
[*.{cpp,hpp,sqf}]
indent_style = tab
indent_size = 2

# 2 space indentation for JSON, XML, and TOML files
[*.{json,xml,toml}]
indent_style = space
indent_size = 2

# 2 space indentation for Markdown files
[*.md]
indent_style = space
indent_size = 2

# Specific settings for makefiles
[{Makefile,makefile,*.mk}]
indent_style = tab
